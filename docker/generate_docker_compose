#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TEMPLATE="$SCRIPT_DIR/docker-compose.template.yaml"
OUTPUT="$SCRIPT_DIR/docker-compose.yaml"

if [ ! -f "$TEMPLATE" ]; then
  echo "[generate] missing template: $TEMPLATE" >&2
  exit 1
fi

{
  printf '%s\n' '# =================================================================='
  printf '%s\n' '# WARNING: This file is auto-generated by docker/generate_docker_compose'
  printf '%s\n' '# Do not modify this file directly. Update docker-compose.template.yaml'
  printf '%s\n' '# and regenerate this file instead.'
  printf '%s\n' '# =================================================================='
  printf '\n'
  cat "$TEMPLATE"
} > "$OUTPUT"

echo "[generate] wrote $OUTPUT"
