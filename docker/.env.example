COMPOSE_PROJECT_NAME=zgi
# Docker starts the complete local stack by default so first-time users can use
# knowledge base, code execution, and plugin features immediately.
# Set this to an empty value or run `./dev/start-docker --core` for the
# lightweight core stack.
COMPOSE_PROFILES=runtime,knowledge

# Docker build mirror defaults.
# Use `./dev/start-docker --china` to apply the recommended China mainland values
# for the current build without editing this file.
BUILD_REGION=global
APT_MIRROR=
APT_SECURITY_MIRROR=
APK_MIRROR=
NPM_REGISTRY=
PIP_INDEX_URL=
UV_INDEX_URL=
GOPROXY=

PUBLIC_PORT=2679
PUBLIC_URL=http://localhost:2679
API_PORT=2670
WEB_PORT=2680
SANDBOX_PORT=2660
RUNNER_PORT=2665
POSTGRES_PORT=5434
REDIS_HOST_PORT=6381
WEAVIATE_PORT=18080
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Reuse application images by default. Set IMAGE_TAG to a branch tag when
# multiple branches build images independently, or keep latest to reuse a
# previously built/pulled stack image.
API_IMAGE_NAME=docker.io/zgiai/zgi-api
WEB_IMAGE_NAME=zgi-web
SANDBOX_IMAGE_NAME=zgi-sandbox
RUNNER_IMAGE_NAME=zgi-runner
IMAGE_TAG=latest

POSTGRES_DB=zgi
POSTGRES_SQL_BASE_DB=zgi_sql_base
POSTGRES_RUNNER_DB=zgi_runner
POSTGRES_SANDBOX_DB=zgi_sandbox
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
REDIS_PASSWORD=
SANDBOX_REDIS_DB=1
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Optional service wiring. The default values match the full local stack.
VECTOR_STORE=weaviate
WEAVIATE_ENDPOINT=http://weaviate:8080
NEO4J_URI=bolt://neo4j:7687
CODE_EXECUTION_ENDPOINT=http://zgi-sandbox:2660
PLUGIN_RUNNER_ENABLED=true
PLUGIN_RUNNER_URL=http://runner:2665

EDITION=SELF_HOSTED

MARKETPLACE_API_URL=https://market.zgiai.com
PM2_INSTANCES=2
WEB_API_CORS_ALLOW_ORIGINS=http://localhost:2679

# Optional web monitoring. These values are passed into the web container.
SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
