COMPOSE_PROJECT_NAME=zgi
# Optional compose profiles:
# - runtime starts sandbox and runner.
# - knowledge starts Weaviate and Neo4j.
# Leave empty for the lightweight core stack.
COMPOSE_PROFILES=

# Docker build mirror defaults.
# Use `./dev/start-docker --china` to apply the recommended China mainland values
# for the current build without editing this file.
BUILD_REGION=global
APT_MIRROR=
APT_SECURITY_MIRROR=
APK_MIRROR=
NPM_REGISTRY=
PIP_INDEX_URL=
UV_INDEX_URL=
GOPROXY=

PUBLIC_PORT=2679
PUBLIC_URL=http://localhost:2679

POSTGRES_DB=zgi
POSTGRES_SQL_BASE_DB=zgi_sql_base
POSTGRES_RUNNER_DB=zgi_runner
POSTGRES_SANDBOX_DB=zgi_sandbox
POSTGRES_USER=postgres
POSTGRES_PASSWORD=zgiai123456
REDIS_PASSWORD=zgiai123456
SANDBOX_REDIS_DB=1
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j123456

# Optional service wiring. The startup helper fills these when you pass
# --runtime, --knowledge, or --full.
VECTOR_STORE=mock
WEAVIATE_ENDPOINT=
NEO4J_URI=
CODE_EXECUTION_ENDPOINT=
PLUGIN_RUNNER_ENABLED=false
PLUGIN_RUNNER_URL=http://runner:2665

EDITION=SELF_HOSTED

MARKETPLACE_API_URL=https://market.zgiai.com
PM2_INSTANCES=2
WEB_API_CORS_ALLOW_ORIGINS=http://localhost:2679
