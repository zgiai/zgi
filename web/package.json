{
  "name": "zgi-web",
  "version": "2.0.0",
  "description": "ZGI Web Scaffold - Modern web application scaffold built with Next.js, TypeScript, and Tailwind CSS",
  "private": true,
  "scripts": {
    "customer:prepare": "node scripts/customer/prepare.mjs",
    "dev": "node scripts/customer/prepare.mjs && node scripts/generate-sensitive-word-filter.mjs && next dev",
    "dev:webpack": "node scripts/customer/prepare.mjs && node scripts/generate-sensitive-word-filter.mjs && next dev --webpack",
    "build": "node scripts/customer/prepare.mjs && node scripts/build-with-resource-defaults.mjs",
    "start": "next start",
    "pm2:start": "node start-pm2.js",
    "pm2:stop": "pm2 stop zgi-web",
    "pm2:restart": "pm2 restart zgi-web",
    "pm2:logs": "pm2 logs zgi-web",
    "pm2:status": "pm2 status",
    "vercel-build": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:workflow-tool-validation": "node scripts/test-workflow-tool-validation.mjs",
    "test:code-node-validation": "node scripts/test-code-node-validation.mjs",
    "type-check": "node scripts/customer/prepare.mjs && node scripts/generate-sensitive-word-filter.mjs && node scripts/check-i18n-route-modules.mjs && tsc --noEmit",
    "check:i18n-routes": "node scripts/check-i18n-route-modules.mjs",
    "validate:agent-templates": "node scripts/validate-agent-templates.mjs",
    "format": "prettier --write .",
    "prepare:sensitive-words": "node scripts/generate-sensitive-word-filter.mjs"
  },
  "keywords": [
    "nextjs",
    "typescript",
    "tailwindcss",
    "scaffold",
    "web-app",
    "zgi"
  ],
  "author": "ZGI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zgiai/zgi.git",
    "directory": "web"
  },
  "bugs": {
    "url": "https://github.com/zgiai/zgi/issues"
  },
  "homepage": "https://github.com/zgiai/zgi#readme",
