# ============================================================
# ZGI Web Platform - Environment Configuration
# ============================================================

# ===== REQUIRED =====
# These variables are essential for the application to run

# Node.js environment (development/production/test)
NODE_ENV=production

# Main API base URL
# For Docker deployment, use the public gateway for local access
# For production, replace with your actual domain (e.g., https://api.yourdomain.com)
NEXT_PUBLIC_API_URL=http://localhost:2679

# Base path for sub-route deployment (e.g., /zgi)
# Keep empty for root deployment
# NEXT_PUBLIC_BASE_PATH=
# BASE_PATH=
# Docker build will automatically fallback between BASE_PATH and NEXT_PUBLIC_BASE_PATH.
# If you set one of them, keep both values consistent to avoid confusion.


# ===== OPTIONAL - Branding & UI =====
# Customize the application appearance

# Application name (default: ZGI)
# Build-time branding value used by metadata/title. Rebuild the image after changing it.
# NEXT_PUBLIC_APP_NAME=ZGI

# Logo URL for light theme (default: /logo.png)
# NEXT_PUBLIC_LOGO_URL=/logo.png

# Logo URL for dark theme (default: /logo_dark.png)
# NEXT_PUBLIC_DARK_LOGO_URL=/logo_dark.png

# Favicon URL override (default: use app router built-in favicon discovery)
# When set, metadata will inject this URL as the favicon source
# Supports internal paths or full external URLs
# Example: /brand/favicon.ico or https://cdn.example.com/favicon.ico
# NEXT_PUBLIC_FAVICON_URL=

# Logo click redirect URL (default: /console)
# Supports internal paths or full external URLs
# Example: /console or https://www.example.com
# NEXT_PUBLIC_LOGO_REDIRECT_URL=/console

# Brand identity for brand-specific UI marks.
# Use zgi for the official ZGI deployment; use a customer brand key such as aiyoung to hide ZGI-only marks.
# NEXT_PUBLIC_BRAND_NAME=zgi

# Redirect URL after logout completes (default: /login)
# Supports internal paths or full external URLs
# Example: /login or https://sso.example.com/logout-success
# NEXT_PUBLIC_LOGOUT_REDIRECT_URL=/login

# Auth page sidebar background image URL
# When set, replaces the default generative background with a custom image
# Example: https://example.com/bg.jpg or /custom-bg.png
# NEXT_PUBLIC_AUTH_BG_IMAGE=

# Console AI chat conversation sidebar background image URL
# Use this for brand-specific deployments such as AiYoung.
# Example: https://example.com/aichat-sidebar-bg.png or /aiyoung/sidebar-bg.png
# NEXT_PUBLIC_AICHAT_SIDEBAR_BG_IMAGE=

# Web app chat conversation history sidebar background image URL
# Use this for brand-specific deployments such as AiYoung.
# Example AiYoung value:
# NEXT_PUBLIC_WEBAPP_CHAT_SIDEBAR_BG_IMAGE=https://cdn.ezv.cn/image/f36c2703-df3f-4a0b-831b-58a2acddbe40.png
# NEXT_PUBLIC_WEBAPP_CHAT_SIDEBAR_BG_IMAGE=

# Hide the auth page left promotional panel (default: false)
# When true, login/register/forgot-password pages use a single-column layout
# NEXT_PUBLIC_HIDE_AUTH_LEFT_PANEL=false

# Disable redirecting authenticated users away from auth pages (default: false)
# When true, logged-in users can stay on /login, /register, and /forgot-password
# NEXT_PUBLIC_DISABLE_AUTHENTICATED_REDIRECT_ON_AUTH_PAGES=false

# Force auth pages to use a single SSO provider (default: empty)
# When set, auth-related pages redirect directly to /console/api/sso/{provider}/start
# Current supported production value in this project is typically: casdoor
# NEXT_PUBLIC_SINGLE_SSO_PROVIDER=casdoor

# Default text icon background color (default: light theme primary)
# Supports any valid CSS color value, e.g. #111111, rgb(17,17,17), oklch(0.205 0 0)
# NEXT_PUBLIC_ICON_BG=oklch(0.205 0 0)

# Default text icon value (default: z)
# NEXT_PUBLIC_ICON_TEXT=z

# Auth page promotional text (bilingual)
# NEXT_PUBLIC_AUTH_TITLE_LINE1_EN=With AI Precision
# NEXT_PUBLIC_AUTH_TITLE_LINE1_ZH=以 AI 精准驱动
# NEXT_PUBLIC_AUTH_TITLE_LINE2_EN=Transform Your Workflow.
# NEXT_PUBLIC_AUTH_TITLE_LINE2_ZH=重塑您的工作流程。
# NEXT_PUBLIC_AUTH_DESCRIPTION_EN=Powerful AI-driven platform...
# NEXT_PUBLIC_AUTH_DESCRIPTION_ZH=强大的 AI 驱动平台...


# ===== OPTIONAL - Localization & Theme =====

# Enable language switcher in UI (default: true)
# Set to false to disable it.
# NEXT_PUBLIC_ENABLE_LANG_SWITCH=true

# Default locale for the app (zh-Hans/en-US, default: zh-Hans)
# NEXT_PUBLIC_DEFAULT_LOCALE=zh-Hans

# Enable theme switcher in UI (default: true)
# NEXT_PUBLIC_ENABLE_THEME_SWITCH=true

# Default theme name (light/dark/ai-young/whale-orange, default: light)
# NEXT_PUBLIC_DEFAULT_THEME=light


# ===== OPTIONAL - API Endpoints =====
# Override specific API endpoints (derived from NEXT_PUBLIC_API_URL if not set)

# Auth API base URL
# NEXT_PUBLIC_AUTH_API_URL=

# Root domain for token cookie synchronization across subdomains
# Example: .xxx.com
# When empty, root-domain token cookie sync is disabled
# NEXT_PUBLIC_ROOT_COOKIE_DOMAIN=

# Upload API base URL
# NEXT_PUBLIC_UPLOAD_API_URL=

# Marketplace API URL
NEXT_PUBLIC_MARKET_API_URL=https://market.zgiai.com

# Optional marketplace distribution channel.
# When empty, the marketplace API resolves channel by Host/CNAME.
# NEXT_PUBLIC_MARKETPLACE_CHANNEL=


# ===== OPTIONAL - Performance Tuning =====

# Workflow editor autosave interval in milliseconds (default: 30000)
# NEXT_PUBLIC_WORKFLOW_AUTOSAVE_INTERVAL_MS=30000

# UI stream rendering throttle interval in milliseconds (default: 120)
# NEXT_PUBLIC_STREAM_RENDER_THROTTLE_MS=120


# ===== OPTIONAL - Monitoring & Debugging =====

# Sentry DSN for error tracking
# Server and edge runtime use SENTRY_DSN; browser runtime uses NEXT_PUBLIC_SENTRY_DSN.
# For TEST-A, set both values to the converted SDK DSN, for example:
# https://<public-key>@sentry.example.com/<project-id>
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# Sentry environment label for grouping events, for example TEST-A.
# SENTRY_ENVIRONMENT=TEST-A
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=TEST-A
# Browser Replay is opt-in to keep the default client bundle lean.
# NEXT_PUBLIC_SENTRY_REPLAY_ENABLED=false
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0

# Disable Next.js telemetry (default: 1)
NEXT_TELEMETRY_DISABLED=1


# ===== OPTIONAL - Model Parameters =====

# Top K max value for model parameters
# NEXT_PUBLIC_TOP_K_MAX_VALUE=

# Indexing max segmentation tokens length
# NEXT_PUBLIC_INDEXING_MAX_SEGMENTATION_TOKENS_LENGTH=


# ===== OPTIONAL - Deployment Mode =====

# Is this the official cloud version? (true/false, default: false)
# When true:
# - Channel page shows official channels
# - Cost center shows wallet, packages, and detailed points breakdown
# - Provider page hides sync buttons
NEXT_PUBLIC_IS_CLOUD=false

# Frontend-only final display filter for model output. Disabled by default.
# NEXT_PUBLIC_SENSITIVE_WORD_FILTER_ENABLED=false
