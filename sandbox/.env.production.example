# Production example for zgi-sandbox.
# Replace values before deployment.

# ===== server =====
ZGI_SANDBOX_SERVER_PORT=2660
ZGI_SANDBOX_API_KEY=<set-secure-api-key>

# ===== public urls =====
ZGI_SANDBOX_ADVERTISE_URL=https://sandbox.internal.example
ZGI_SANDBOX_PUBLIC_BASE_URL=https://sandbox.example

# ===== runtime =====
ZGI_SANDBOX_ENV=production
ZGI_SANDBOX_RUNTIME_BACKEND=linux-secure
ZGI_SANDBOX_DATA_DIR=/var/lib/zgi-sandbox
ZGI_SANDBOX_WORKER_ID=zgi-sandbox-worker-1
ZGI_SANDBOX_SECURE_ROOTFS=/srv/zgi-sandbox/rootfs
ZGI_SANDBOX_DEPENDENCY_ROOTFS_DIR=/srv/zgi-sandbox/profiles
ZGI_SANDBOX_BWRAP_BINARY=bwrap
ZGI_SANDBOX_SECURE_RUNTIME_CPU_SECONDS=2
ZGI_SANDBOX_SECURE_RUNTIME_MEMORY_BYTES=268435456
ZGI_SANDBOX_SECURE_RUNTIME_PROCESS_LIMIT=64
ZGI_SANDBOX_SECURE_RUNTIME_OPEN_FILE_LIMIT=128

# ===== execution limits =====
ZGI_SANDBOX_LITE_MAX_WORKERS=4
ZGI_SANDBOX_LITE_WORKER_TIMEOUT=5
ZGI_SANDBOX_OUTPUT_LIMIT_KB=64
ZGI_SANDBOX_MAX_ACTIVE=6
ZGI_SANDBOX_MAX_ACTIVE_PER_ORGANIZATION=2
ZGI_SANDBOX_MAX_CONCURRENT_EXECUTIONS=8
ZGI_SANDBOX_MAX_CONCURRENT_EXECUTIONS_PER_PROFILE=4
ZGI_SANDBOX_MAX_CONCURRENT_EXECUTIONS_PER_ORGANIZATION=4
ZGI_SANDBOX_MAX_EXECUTIONS_PER_MINUTE_PER_ORGANIZATION=60
ZGI_SANDBOX_MAX_NETWORK_REQUESTS_PER_MINUTE_PER_ORGANIZATION=120
ZGI_SANDBOX_MAX_QUEUED_EXECUTIONS_PER_ORGANIZATION=8
ZGI_SANDBOX_QUEUE_TIMEOUT_MS=5000
ZGI_SANDBOX_SHUTDOWN_TIMEOUT_SECONDS=15
ZGI_SANDBOX_SESSION_TTL_SECONDS=1800
ZGI_SANDBOX_INTERACTIVE_TTL_SECONDS=3600
ZGI_SANDBOX_COMMAND_TIMEOUT_SECONDS=15
ZGI_SANDBOX_MAX_FILE_SIZE_KB=256
ZGI_SANDBOX_MAX_WORKSPACE_FILES=1000
ZGI_SANDBOX_MAX_WORKSPACE_BYTES=104857600
ZGI_SANDBOX_MAX_WORKSPACE_BYTES_PER_ORGANIZATION=524288000
ZGI_SANDBOX_MAX_ARTIFACT_MANIFEST_FILES=100
ZGI_SANDBOX_MAX_ARTIFACT_MANIFEST_BYTES=10485760
ZGI_SANDBOX_MAX_ARTIFACT_BYTES_PER_ORGANIZATION=1073741824
ZGI_SANDBOX_MAX_DEPENDENCY_PROFILES_PER_ORGANIZATION=8
ZGI_SANDBOX_MAX_DEPENDENCY_PROFILE_SIZE_BYTES=536870912
ZGI_SANDBOX_DEPENDENCY_PROFILE_BUILD_TIMEOUT_SECONDS=600
ZGI_SANDBOX_DEPENDENCY_BUILD_COMMAND=/usr/local/bin/zgi-sandbox-build-dependency-profile
ZGI_SANDBOX_CACHE_TTL_SECONDS=30
ZGI_SANDBOX_PROXY_TIMEOUT_SECONDS=20
ZGI_SANDBOX_EGRESS_PROXY_MAX_BODY_BYTES=1048576

# ===== observer retention =====
ZGI_SANDBOX_OBSERVER_RETENTION_DAYS=30
ZGI_SANDBOX_OBSERVER_MAX_EVENTS=100000

# ===== internal services =====
ZGI_SANDBOX_DATABASE_URL=postgres://zgi_sandbox:<set-database-password>@sandbox-postgres:5432/zgi_sandbox?sslmode=require
ZGI_SANDBOX_REDIS_ADDR=sandbox-redis:6379
ZGI_SANDBOX_REDIS_PASSWORD=<set-redis-password>
ZGI_SANDBOX_REDIS_DB=0
