# ===== server =====
ZGI_SANDBOX_SERVER_PORT=2660
ZGI_SANDBOX_API_KEY=

# ===== public urls =====
ZGI_SANDBOX_ADVERTISE_URL=http://localhost:2660
ZGI_SANDBOX_PUBLIC_BASE_URL=http://localhost:2660

# ===== runtime =====
ZGI_SANDBOX_ENV=local
ZGI_SANDBOX_RUNTIME_BACKEND=preview
ZGI_SANDBOX_DATA_DIR=/var/lib/zgi-sandbox

# ===== execution limits =====
ZGI_SANDBOX_LITE_MAX_WORKERS=4
ZGI_SANDBOX_LITE_WORKER_TIMEOUT=5
ZGI_SANDBOX_OUTPUT_LIMIT_KB=64
ZGI_SANDBOX_MAX_ACTIVE=6
ZGI_SANDBOX_MAX_ACTIVE_PER_ORGANIZATION=0
ZGI_SANDBOX_MAX_CONCURRENT_EXECUTIONS=0
ZGI_SANDBOX_MAX_CONCURRENT_EXECUTIONS_PER_PROFILE=0
ZGI_SANDBOX_MAX_CONCURRENT_EXECUTIONS_PER_ORGANIZATION=0
ZGI_SANDBOX_MAX_EXECUTIONS_PER_MINUTE_PER_ORGANIZATION=0
ZGI_SANDBOX_MAX_QUEUED_EXECUTIONS_PER_ORGANIZATION=0
ZGI_SANDBOX_QUEUE_TIMEOUT_MS=5000
ZGI_SANDBOX_SHUTDOWN_TIMEOUT_SECONDS=10
ZGI_SANDBOX_SESSION_TTL_SECONDS=1800
ZGI_SANDBOX_INTERACTIVE_TTL_SECONDS=3600
ZGI_SANDBOX_COMMAND_TIMEOUT_SECONDS=15
ZGI_SANDBOX_MAX_FILE_SIZE_KB=256
ZGI_SANDBOX_MAX_WORKSPACE_FILES=0
ZGI_SANDBOX_MAX_WORKSPACE_BYTES=0
ZGI_SANDBOX_MAX_WORKSPACE_BYTES_PER_ORGANIZATION=0
ZGI_SANDBOX_MAX_ARTIFACT_MANIFEST_FILES=0
ZGI_SANDBOX_MAX_ARTIFACT_MANIFEST_BYTES=0
ZGI_SANDBOX_MAX_ARTIFACT_BYTES_PER_ORGANIZATION=0
ZGI_SANDBOX_MAX_DEPENDENCY_PROFILES_PER_ORGANIZATION=0
ZGI_SANDBOX_MAX_DEPENDENCY_PROFILE_SIZE_BYTES=536870912
ZGI_SANDBOX_DEPENDENCY_PROFILE_BUILD_TIMEOUT_SECONDS=600
ZGI_SANDBOX_CACHE_TTL_SECONDS=30
ZGI_SANDBOX_PROXY_TIMEOUT_SECONDS=20

# ===== observer retention =====
ZGI_SANDBOX_OBSERVER_RETENTION_DAYS=7
ZGI_SANDBOX_OBSERVER_MAX_EVENTS=10000

# ===== internal services =====
ZGI_SANDBOX_DATABASE_URL=
ZGI_SANDBOX_REDIS_ADDR=sandbox-redis:6379
ZGI_SANDBOX_REDIS_PASSWORD=
ZGI_SANDBOX_REDIS_DB=0

# ===== compose postgres =====
POSTGRES_DB=zgi_sandbox
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ===== worker =====
ZGI_SANDBOX_WORKER_ID=zgi-sandbox-local

# ===== secure runtime optional =====
ZGI_SANDBOX_SECURE_ROOTFS=
ZGI_SANDBOX_DEPENDENCY_ROOTFS_DIR=
ZGI_SANDBOX_BWRAP_BINARY=bwrap
