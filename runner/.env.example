# ============================================
# Runner Configuration
# Copy to .env and configure before running:
#   docker compose up -d
# ============================================

# HTTP service
EXECUTOR_HTTP_PORT=2665
EXECUTOR_PLUGIN_HOME=/app/plugins
EXECUTOR_WORKSPACE_PATH=/app/workspace
EXECUTOR_PACKAGE_CACHE_PATH=/app/cache

# Runner auth
EXECUTOR_API_KEY=
EXECUTOR_ADMIN_API_KEYS=
EXECUTOR_READONLY_API_KEYS=

# Database
# Reuse the Postgres container on the existing Docker network
EXECUTOR_DB_DRIVER=postgres
EXECUTOR_DB_HOST=zgi-postgres
EXECUTOR_DB_PORT=5432
EXECUTOR_DB_USER=postgres
EXECUTOR_DB_PASSWORD=
EXECUTOR_DB_NAME=zgi_runner
EXECUTOR_DB_SSL_MODE=disable
EXECUTOR_DB_OPTIONS=
EXECUTOR_DB_MAX_IDLE_CONNS=5
EXECUTOR_DB_MAX_OPEN_CONNS=20
EXECUTOR_DB_CONN_MAX_LIFETIME=1h
EXECUTOR_DB_CONN_MAX_IDLE_TIME=10m

# Redis
# Reuse the Redis container on the existing Docker network
EXECUTOR_REDIS_HOST=zgi-redis
EXECUTOR_REDIS_PORT=6379
EXECUTOR_REDIS_USERNAME=
EXECUTOR_REDIS_PASSWORD=
EXECUTOR_REDIS_DB=0
EXECUTOR_REDIS_USE_TLS=false
EXECUTOR_REDIS_DIAL_TIMEOUT=5s
EXECUTOR_REDIS_READ_TIMEOUT=3s
EXECUTOR_REDIS_WRITE_TIMEOUT=3s

# Redis Sentinel (optional)
EXECUTOR_REDIS_SENTINEL_ENABLED=false
EXECUTOR_REDIS_SENTINEL_MASTER=redis-primary
EXECUTOR_REDIS_SENTINEL_ADDRS=
EXECUTOR_REDIS_SENTINEL_USERNAME=
EXECUTOR_REDIS_SENTINEL_PASSWORD=

# Runtime interpreters
EXECUTOR_PYTHON_INTERPRETER=python3
EXECUTOR_NODE_INTERPRETER=node
EXECUTOR_PIP_COMMAND=pip3
EXECUTOR_NPM_COMMAND=npm
EXECUTOR_UV_PATH=/usr/local/bin/uv
EXECUTOR_PYTHON_ENV_INIT_TIMEOUT=10m
EXECUTOR_PYTHON_COMPILE_EXTRA_ARGS=
# Optional for China mainland networks:
# EXECUTOR_PIP_MIRROR_URL=https://pypi.tuna.tsinghua.edu.cn/simple
EXECUTOR_PIP_MIRROR_URL=
EXECUTOR_PIP_PREFER_BINARY=false
EXECUTOR_PIP_VERBOSE=false
EXECUTOR_PIP_EXTRA_ARGS=
# Optional for China mainland networks:
# NPM_CONFIG_REGISTRY=https://registry.npmmirror.com
NPM_CONFIG_REGISTRY=
EXECUTOR_INSTALL_TIMEOUT=2m
EXECUTOR_MAX_PACKAGE_SIZE_BYTES=0
EXECUTOR_MAX_CONCURRENT_RUNS=0

# Access control
EXECUTOR_MULTI_TENANT_ENABLED=false
EXECUTOR_REQUIRE_MANIFEST_SIGNATURE=false
EXECUTOR_SIGNATURE_PUBLIC_KEY_PATH=
EXECUTOR_SIGNATURE_ALGORITHM=rsa
EXECUTOR_RATE_LIMIT_PER_MINUTE=0
EXECUTOR_TENANT_RATE_LIMIT_PER_MINUTE=0

# Runtime buffer and timeout
EXECUTOR_STDOUT_BUFFER_SIZE=4096
EXECUTOR_STDOUT_MAX_BUFFER_SIZE=5242880
EXECUTOR_SHUTDOWN_TIMEOUT=15s

# Proxy
EXECUTOR_HTTP_PROXY=
EXECUTOR_HTTPS_PROXY=
EXECUTOR_NO_PROXY=localhost,127.0.0.1
