#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
MODE="check"
TIMESTAMP="$(date +"%Y%m%d_%H%M%S")"

MAPPINGS=(
  "docker/.env.example|docker/.env|docker compose"
  "api/.env.example|api/.env|api local"
  "api/.env.docker.example|api/.env.docker|api docker"
  "web/.env.example|web/.env.local|web local"
  "sandbox/.env.example|sandbox/.env|sandbox"
  "runner/.env.example|runner/.env|runner"
)

usage() {
  cat <<'EOF'
Usage: ./dev/check-env [--sync]

Default mode only reports differences.
--sync creates a backup and appends missing keys from each template.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --sync)
      MODE="sync"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

parse_env_file() {
  local file_path="$1"
  awk '
    /^[[:space:]]*#/ { next }
    /^[[:space:]]*$/ { next }
    index($0, "=") == 0 { next }
    {
      key = $0
      sub(/=.*/, "", key)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", key)
      value = $0
      sub(/^[^=]*=/, "", value)
      print key "\t" value
    }
  ' "$file_path"
}

append_missing_keys() {
  local template_path="$1"
  local target_path="$2"

  local tmp_file
  local appended_count=0
  local backup_path
  tmp_file="$(mktemp)"

  while IFS= read -r line || [ -n "$line" ]; do
    if [[ "$line" =~ ^[[:space:]]*# ]] || [[ "$line" =~ ^[[:space:]]*$ ]] || [[ "$line" != *=* ]]; then
      continue
    fi

    local key="${line%%=*}"
    key="$(trim "$key")"
    [ -z "$key" ] && continue

    if ! env_key_exists "$target_path" "$key"; then
      printf '%s\n' "$line" >> "$tmp_file"
      appended_count=$((appended_count + 1))
    fi
  done < "$template_path"

  if [ "$appended_count" -eq 0 ]; then
    rm -f "$tmp_file"
    return 0
  fi

  backup_path="${target_path}.bak.${TIMESTAMP}"
  cp "$target_path" "$backup_path"

  {
    printf '\n# Added by dev/check-env --sync on %s\n' "$TIMESTAMP"
    cat "$tmp_file"
  } >> "$target_path"

  rm -f "$tmp_file"
  echo "  synced missing keys: $appended_count"
  echo "  backup: ${backup_path#$ROOT/}"
}

env_key_exists() {
  local file_path="$1"
  local wanted_key="$2"

  parse_env_file "$file_path" | awk -F '\t' -v wanted="$wanted_key" '
    $1 == wanted { found = 1 }
    END { exit found ? 0 : 1 }
  '
}

env_value_for_key() {
  local file_path="$1"
  local wanted_key="$2"

  parse_env_file "$file_path" | awk -F '\t' -v wanted="$wanted_key" '
    $1 == wanted { value = $2; found = 1 }
    END {
      if (!found) exit 1
      print value
    }
  '
}

check_mapping() {
  local template_rel="$1"
  local target_rel="$2"
  local label="$3"
  local template_path="$ROOT/$template_rel"
  local target_path="$ROOT/$target_rel"

  local missing_count=0
  local changed_count=0
  local stale_count=0

  echo "[check-env] $label"

  if [ ! -f "$template_path" ]; then
    echo "  template missing: $template_rel"
    return 1
  fi

  if [ ! -f "$target_path" ]; then
    echo "  target missing: $target_rel"
    return 0
  fi

  while IFS=$'\t' read -r key template_value; do
    [ -z "$key" ] && continue

    if ! env_key_exists "$target_path" "$key"; then
      echo "  missing key: $key"
      missing_count=$((missing_count + 1))
      continue
    fi

    target_value="$(env_value_for_key "$target_path" "$key")"
    if [ "$(trim "$template_value")" != "$(trim "$target_value")" ]; then
      echo "  changed value: $key"
      changed_count=$((changed_count + 1))
    fi
  done < <(parse_env_file "$template_path")

  while IFS=$'\t' read -r key _value; do
    [ -z "$key" ] && continue

    if ! env_key_exists "$template_path" "$key"; then
      echo "  extra key: $key"
      stale_count=$((stale_count + 1))
    fi
  done < <(parse_env_file "$target_path")

  if [ "$missing_count" -eq 0 ] && [ "$changed_count" -eq 0 ] && [ "$stale_count" -eq 0 ]; then
    echo "  ok"
  else
    echo "  summary: missing=$missing_count changed=$changed_count extra=$stale_count"
    if [ "$MODE" = "sync" ] && [ "$missing_count" -gt 0 ]; then
      append_missing_keys "$template_path" "$target_path"
    fi
  fi
}

overall_status=0

for mapping in "${MAPPINGS[@]}"; do
  IFS='|' read -r template_rel target_rel label <<< "$mapping"
  if ! check_mapping "$template_rel" "$target_rel" "$label"; then
    overall_status=1
  fi
done

exit "$overall_status"
