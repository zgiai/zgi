#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

display_path() {
  local target_path="$1"
  echo "${target_path#$ROOT/}"
}

copy_if_missing() {
  local source_path="$1"
  local target_path="$2"

  if [ ! -f "$source_path" ]; then
    echo "[bootstrap] missing template: $source_path" >&2
    exit 1
  fi

  if [ -f "$target_path" ]; then
    echo "[bootstrap] keep existing $(display_path "$target_path")"
    return 0
  fi

  mkdir -p "$(dirname "$target_path")"
  cp "$source_path" "$target_path"
  echo "[bootstrap] created $(display_path "$target_path")"
}

generate_secret_32() {
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex 16
    return 0
  fi

  if command -v shasum >/dev/null 2>&1; then
    printf '%s' "$(date +%s)-$$-$RANDOM" | shasum -a 256 | cut -c 1-32
    return 0
  fi

  if command -v sha256sum >/dev/null 2>&1; then
    printf '%s' "$(date +%s)-$$-$RANDOM" | sha256sum | cut -c 1-32
    return 0
  fi

  printf '%s\n' "zgi-local-docker-api-key-0000001"
}

is_unset_or_placeholder() {
  local value="$1"
  case "$value" in
    ""|"replace-with-strong-random-secret"|"replace-with-32-byte-random-key"|"change-me-in-production"|"change-me")
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

ensure_env_value() {
  local target_path="$1"
  local key="$2"
  local value="$3"
  local current=""

  if [ ! -f "$target_path" ]; then
    echo "[bootstrap] missing env file: $target_path" >&2
    exit 1
  fi

  if grep -q "^${key}=" "$target_path"; then
    current="$(grep "^${key}=" "$target_path" | tail -n 1 | cut -d= -f2-)"
    if is_unset_or_placeholder "$current"; then
      sed -i.bak "s|^${key}=.*|${key}=${value}|" "$target_path"
      rm -f "${target_path}.bak"
      echo "[bootstrap] updated $(display_path "$target_path") ${key}"
    fi
    return 0
  fi

  printf '\n%s=%s\n' "$key" "$value" >> "$target_path"
  echo "[bootstrap] added $(display_path "$target_path") ${key}"
}

replace_env_value_if_current() {
  local target_path="$1"
  local key="$2"
  local old_value="$3"
  local new_value="$4"
  local current=""

  if [ ! -f "$target_path" ] || ! grep -q "^${key}=" "$target_path"; then
    return 0
  fi

  current="$(grep "^${key}=" "$target_path" | tail -n 1 | cut -d= -f2-)"
  if [ "$current" = "$old_value" ]; then
    sed -i.bak "s|^${key}=.*|${key}=${new_value}|" "$target_path"
    rm -f "${target_path}.bak"
    echo "[bootstrap] updated $(display_path "$target_path") ${key}"
  fi
}

remove_env_key() {
  local target_path="$1"
  local key="$2"

  if [ ! -f "$target_path" ] || ! grep -q "^${key}=" "$target_path"; then
    return 0
  fi

  sed -i.bak "/^${key}=.*/d" "$target_path"
  rm -f "${target_path}.bak"
  echo "[bootstrap] removed $(display_path "$target_path") ${key}"
}

get_env_value() {
  local target_path="$1"
  local key="$2"

  if [ ! -f "$target_path" ] || ! grep -q "^${key}=" "$target_path"; then
    return 1
  fi

  grep "^${key}=" "$target_path" | tail -n 1 | cut -d= -f2-
}

copy_if_missing "$ROOT/docker/.env.example" "$ROOT/docker/.env"
copy_if_missing "$ROOT/api/.env.example" "$ROOT/api/.env"
copy_if_missing "$ROOT/api/.env.docker.example" "$ROOT/api/.env.docker"
copy_if_missing "$ROOT/web/.env.example" "$ROOT/web/.env.local"
copy_if_missing "$ROOT/sandbox/.env.example" "$ROOT/sandbox/.env"
copy_if_missing "$ROOT/runner/.env.example" "$ROOT/runner/.env"

api_secret="$(generate_secret_32)"
api_docker_secret="$(generate_secret_32)"
postgres_password="$(generate_secret_32)"
redis_password="$(generate_secret_32)"
runner_api_key="$(generate_secret_32)"
sandbox_postgres_password="$(generate_secret_32)"
ensure_env_value "$ROOT/api/.env" "SECRET_KEY" "$(generate_secret_32)"
ensure_env_value "$ROOT/api/.env" "API_KEY_ENCRYPTION_KEY" "$api_secret"
ensure_env_value "$ROOT/api/.env.docker" "SECRET_KEY" "$(generate_secret_32)"
ensure_env_value "$ROOT/api/.env.docker" "API_KEY_ENCRYPTION_KEY" "$api_docker_secret"
replace_env_value_if_current "$ROOT/api/.env.docker" "SQL_BASE_INTERNAL_DB" "zgi" "zgi_sql_base"
replace_env_value_if_current "$ROOT/api/.env" "NEO4J_URI" "bolt://localhost:7687" ""
replace_env_value_if_current "$ROOT/api/.env.docker" "NEO4J_URI" "bolt://neo4j:7687" ""
replace_env_value_if_current "$ROOT/docker/.env" "NEO4J_URI" "bolt://neo4j:7687" ""
remove_env_key "$ROOT/api/.env" "NEO4J_URI"
remove_env_key "$ROOT/api/.env" "NEO4J_USERNAME"
remove_env_key "$ROOT/api/.env" "NEO4J_PASSWORD"
remove_env_key "$ROOT/api/.env" "NEO4J_DATABASE"
remove_env_key "$ROOT/api/.env.docker" "NEO4J_URI"
remove_env_key "$ROOT/api/.env.docker" "NEO4J_USERNAME"
remove_env_key "$ROOT/api/.env.docker" "NEO4J_PASSWORD"
remove_env_key "$ROOT/api/.env.docker" "NEO4J_DATABASE"
remove_env_key "$ROOT/docker/.env" "NEO4J_URI"
remove_env_key "$ROOT/docker/.env" "NEO4J_USERNAME"
remove_env_key "$ROOT/docker/.env" "NEO4J_PASSWORD"
remove_env_key "$ROOT/docker/.env" "NEO4J_DATABASE"
ensure_env_value "$ROOT/docker/.env" "PUBLIC_PORT" "2679"
public_port="$(get_env_value "$ROOT/docker/.env" "PUBLIC_PORT" || printf '%s' "2679")"
ensure_env_value "$ROOT/docker/.env" "PUBLIC_URL" "http://localhost:${public_port}"
ensure_env_value "$ROOT/docker/.env" "POSTGRES_PASSWORD" "$postgres_password"
ensure_env_value "$ROOT/docker/.env" "REDIS_PASSWORD" "$redis_password"

postgres_password="$(get_env_value "$ROOT/docker/.env" "POSTGRES_PASSWORD" || printf '%s' "$postgres_password")"
redis_password="$(get_env_value "$ROOT/docker/.env" "REDIS_PASSWORD" || printf '%s' "$redis_password")"
ensure_env_value "$ROOT/api/.env" "DB_PASSWORD" "$postgres_password"
ensure_env_value "$ROOT/api/.env" "REDIS_PASSWORD" "$redis_password"
ensure_env_value "$ROOT/api/.env.docker" "DB_PASSWORD" "$postgres_password"
ensure_env_value "$ROOT/api/.env.docker" "REDIS_PASSWORD" "$redis_password"

ensure_env_value "$ROOT/runner/.env" "EXECUTOR_API_KEY" "$runner_api_key"
runner_api_key="$(get_env_value "$ROOT/runner/.env" "EXECUTOR_API_KEY" || printf '%s' "$runner_api_key")"
ensure_env_value "$ROOT/api/.env" "PLUGIN_RUNNER_API_KEY" "$runner_api_key"
ensure_env_value "$ROOT/api/.env.docker" "PLUGIN_RUNNER_API_KEY" "$runner_api_key"
ensure_env_value "$ROOT/runner/.env" "EXECUTOR_DB_PASSWORD" "$postgres_password"
ensure_env_value "$ROOT/runner/.env" "EXECUTOR_REDIS_PASSWORD" "$redis_password"

ensure_env_value "$ROOT/sandbox/.env" "POSTGRES_PASSWORD" "$sandbox_postgres_password"
sandbox_postgres_password="$(get_env_value "$ROOT/sandbox/.env" "POSTGRES_PASSWORD" || printf '%s' "$sandbox_postgres_password")"
ensure_env_value "$ROOT/sandbox/.env" "ZGI_SANDBOX_DATABASE_URL" "postgres://postgres:${sandbox_postgres_password}@sandbox-postgres:5432/zgi_sandbox?sslmode=disable"

echo "[bootstrap] generate docker compose"
"$ROOT/docker/generate_docker_compose"

echo "[bootstrap] done"
