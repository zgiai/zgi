#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
WEB_ROOT="$ROOT/web"

usage() {
  cat <<'EOF'
Usage: CUSTOMER_REPO=... CUSTOMER_REPO_PATH=... ./dev/customer-prepare-docker

Prepare external customer customizations without requiring Node.js on the host.
The script runs a temporary Docker container, mounts ./web, and writes generated
files back to the host workspace.

Environment:
  CUSTOMER_PATH       Local customization path on the host. When set, it is mounted read-only.
  CUSTOMER_REPO       Git repository URL for customization sources.
  CUSTOMER_REF        Git ref, branch, or tag. Defaults to main in the prepare script.
  CUSTOMER_REPO_PATH  Directory inside CUSTOMER_REPO, for example blue-ocean-agent.
  CUSTOMER_SLUG       Public asset slug, for example blue-ocean-agent.
  CUSTOMER_REQUIRED   true/false. When true, missing customization fails.

Examples:
  CUSTOMER_REPO=https://github.com/zgiai/zgi-customizations.git \
  CUSTOMER_REF=master \
  CUSTOMER_REPO_PATH=blue-ocean-agent \
  CUSTOMER_SLUG=blue-ocean-agent \
  CUSTOMER_REQUIRED=true \
  ./dev/customer-prepare-docker

  CUSTOMER_REPO=git@github.com:zgiai/zgi-customizations.git \
  CUSTOMER_REF=master \
  CUSTOMER_REPO_PATH=blue-ocean-agent \
  CUSTOMER_SLUG=blue-ocean-agent \
  CUSTOMER_REQUIRED=true \
  ./dev/customer-prepare-docker

  CUSTOMER_PATH=/path/to/zgi-customizations/blue-ocean-agent \
  CUSTOMER_SLUG=blue-ocean-agent \
  CUSTOMER_REQUIRED=true \
  ./dev/customer-prepare-docker
EOF
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

if ! command -v docker >/dev/null 2>&1; then
  echo "[customer-prepare-docker] docker is required" >&2
  exit 1
fi

mkdir -p "$WEB_ROOT"

docker_args=(
  run
  --rm
  -v "$WEB_ROOT:/app/web"
  -w /app/web
  -e CUSTOMER_REPO
  -e CUSTOMER_REF
  -e CUSTOMER_REPO_PATH
  -e CUSTOMER_SLUG
  -e CUSTOMER_REQUIRED
)

container_customer_path=""
if [ -n "${CUSTOMER_PATH:-}" ]; then
  if [ ! -d "$CUSTOMER_PATH" ]; then
    echo "[customer-prepare-docker] CUSTOMER_PATH does not exist: $CUSTOMER_PATH" >&2
    exit 1
  fi
  container_customer_path="/customer-source"
  docker_args+=(
    -v "$CUSTOMER_PATH:$container_customer_path:ro"
    -e "CUSTOMER_PATH=$container_customer_path"
  )
else
  docker_args+=(-e CUSTOMER_PATH)
fi

ssh_auth_sock="${SSH_AUTH_SOCK:-}"
if [ "$(uname -s 2>/dev/null || true)" = "Darwin" ]; then
  ssh_auth_sock="/run/host-services/ssh-auth.sock"
fi

if [ -n "$ssh_auth_sock" ]; then
  docker_args+=(
    -v "$ssh_auth_sock:/ssh-agent"
    -e SSH_AUTH_SOCK=/ssh-agent
    -e "GIT_SSH_COMMAND=ssh -o StrictHostKeyChecking=accept-new"
  )
fi

if command -v id >/dev/null 2>&1; then
  docker_args+=(
    -e "HOST_UID=$(id -u)"
    -e "HOST_GID=$(id -g)"
  )
else
  docker_args+=(
    -e HOST_UID=1000
    -e HOST_GID=1000
  )
fi

echo "[customer-prepare-docker] preparing customer customization"
docker "${docker_args[@]}" node:20-alpine sh -lc '
  set -e
  apk add --no-cache git openssh-client >/dev/null
  node scripts/customer/prepare.mjs
  chown -R "${HOST_UID}:${HOST_GID}" \
    /app/web/.customer-tmp \
    /app/web/src/customer/generated \
    /app/web/public/customer 2>/dev/null || true
'

echo "[customer-prepare-docker] done"
