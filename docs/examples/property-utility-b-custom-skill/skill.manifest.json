{
  "entrypoint": "scripts/run.py",
  "language": "python3",
  "timeout_ms": 60000,
  "allowed_artifact_paths": ["artifacts"],
  "max_artifact_count": 10,
  "max_artifact_bytes": 2097152,
  "result_mode": "mixed",
  "input_files": [
    {
      "name": "confirmation",
      "argument": "confirmation_file_id",
      "required": false,
      "extensions": [".xlsx"],
      "mime_types": [
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
      ],
      "max_bytes": 10485760
    },
    {
      "name": "confirmations",
      "argument": "confirmation_file_ids",
      "required": false,
      "multiple": true,
      "max_count": 10,
      "extensions": [".xlsx"],
      "mime_types": [
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
      ],
      "max_bytes": 10485760
    }
  ]
}
