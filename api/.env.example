## Usage Instructions
# 1. If you start the API locally with Go commands, copy this file to `.env`
# 2. If you start the API with Docker Compose, copy `.env.docker.example` to `.env.docker`
# 3. The default values below are aligned with the ports and credentials exposed by `docker-compose.yml`, so local startup can work directly with Docker-based dependencies
# 4. The API always loads the project root `.env` file in both development and production
# 5. Adjust the values only when you use external services or locally installed dependencies instead of Docker Compose

## Basic Configuration
# Application name
APP_NAME=ZGI-GinKit

# Server Configuration
# Server running mode (debug/production)
SERVER_MODE=debug
# Environment marker (local/dev/production)
ENV=local
# Server listening port
SERVER_PORT=2670
# Read timeout (seconds)
SERVER_READ_TIMEOUT=3600
# Write timeout (seconds)
SERVER_WRITE_TIMEOUT=3600
# Maximum request header size (bytes)
SERVER_MAX_HEADER_BYTES=1048576

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:2679,http://localhost:3000,https://app.zgi.ai
# Leave empty to use default origins
WEB_API_CORS_ALLOW_ORIGINS=http://localhost:2679,http://localhost:3000

## Log Configuration
# Log level (debug/info/warn/error). Use debug locally; use info for shared environments.
LOG_LEVEL=debug
# Log file path. Use an absolute path in production, for example /var/log/zgi-api/app.log.
LOG_FILENAME=logs/app.log
# Maximum size of a single log file (MB)
LOG_MAX_SIZE=100
# Log file retention days
LOG_MAX_AGE=15
# Maximum number of old log files to retain
LOG_MAX_BACKUPS=7
# Whether to compress old log files
LOG_COMPRESS=true

# Application Basic Information
# Application version
APP_VERSION=1.0.0
# Secret key for JWT signing and file signatures. Generate a unique value before production use.
SECRET_KEY=replace-with-strong-random-secret
# Token expiration time (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Deployment edition marker for cloud/self-hosted branching
ZGI_EDITION=SELF_HOSTED
# File access URL
FILES_URL=http://localhost:2679
# Internal file access URL (optional)
INTERNAL_FILES_URL=
# File access token validity period (seconds)
FILES_ACCESS_TIMEOUT=3600

## Database Configuration
# Database driver
DB_DRIVER=postgres
# Database host
DB_HOST=localhost
# Database port
DB_PORT=5434
# Database username
DB_USERNAME=postgres
# Database password (must be set)
DB_PASSWORD=
# Database name
DB_NAME=zgi
# SSL mode
DB_SSLMODE=disable
# Timezone setting
DB_TIMEZONE=Asia/Shanghai
# Maximum idle connections
DB_MAX_IDLE_CONNS=10
# Maximum open connections
DB_MAX_OPEN_CONNS=100
# Connection maximum lifetime (seconds)
DB_CONN_MAX_LIFETIME=3600

## Redis Configuration
# Redis host
REDIS_HOST=localhost
# Redis port
REDIS_PORT=6381
# Redis password
REDIS_PASSWORD=
# Redis database index
REDIS_DB=0
# Connection pool size
REDIS_POOL_SIZE=10
# Minimum idle connections
REDIS_MIN_IDLE_CONNS=5

## Authentication and Security
# Whether to enable public deployment
PUBLIC_DEPLOYMENT_ENABLED=false
# Whether to enable email verification code login
ENABLE_EMAIL_CODE_LOGIN=false
# Whether to enable email/password login
ENABLE_EMAIL_PASSWORD_LOGIN=true
# Enable social OAuth login entrypoints
ENABLE_SOCIAL_OAUTH_LOGIN=false
# Whether user self-registration is allowed
ALLOW_REGISTER=false
# Whether workspace creation is allowed
ALLOW_CREATE_WORKSPACE=false
# Whether enterprise features are enabled
ENTERPRISE_ENABLED=false
# Whether marketplace features are enabled
MARKETPLACE_ENABLED=true
# Maximum plugin package size in bytes (optional)
PLUGIN_MAX_PACKAGE_SIZE=
# Static admin token for self-hosted platform identity calls
ZGI_ADMIN_PASS=
# Master verification code for testing/admin override (optional)
MASTER_VERIFICATION_CODE=

# Casdoor host, for example: https://door.example.com
CASDOOR_HOST=
# Casdoor application client ID
CASDOOR_CLIENT_ID=
# Casdoor application client secret
CASDOOR_CLIENT_SECRET=
# Backend callback URL registered in Casdoor
CASDOOR_REDIRECT_URI=
# OIDC scopes requested from Casdoor
CASDOOR_SCOPES=openid profile email
# Frontend landing URL that consumes backend SSO ticket
SSO_FRONTEND_CALLBACK_URL=

## Error Reporting
# Sentry DSN for error reporting (optional)
# For TEST-A, use the converted SDK DSN:
# https://<public-key>@sentry.example.com/<project-id>
SENTRY_DSN=
# Sentry environment label for grouping events. Defaults to ENV when empty.
# For TEST-A deployment, set SENTRY_ENVIRONMENT=TEST-A.
SENTRY_ENVIRONMENT=

## Storage Configuration
# Storage type (supported types: opendal, aliyun-oss, qiniu, s3)
STORAGE_TYPE=opendal
# OpenDAL/local base path
OPENDAL_BASE_PATH=./storage/opendal

# Aliyun OSS Storage Configuration
# Aliyun OSS bucket name
ALIYUN_OSS_BUCKET_NAME=
# Aliyun OSS access key ID
ALIYUN_OSS_ACCESS_KEY=
# Aliyun OSS access key secret
ALIYUN_OSS_SECRET_KEY=
# Aliyun OSS endpoint (e.g., oss-cn-hangzhou.aliyuncs.com)
ALIYUN_OSS_ENDPOINT=
# Aliyun OSS authentication version (v1/v4)
ALIYUN_OSS_AUTH_VERSION=v1
# Aliyun OSS region (e.g., cn-hangzhou)
ALIYUN_OSS_REGION=
# Aliyun OSS storage path prefix
ALIYUN_OSS_PATH=

# S3 Storage Configuration
# S3 access key
S3_ACCESS_KEY=
# S3 secret key
S3_SECRET_KEY=
# S3 region
S3_REGION=
# S3 bucket name
S3_BUCKET_NAME=
# S3 endpoint URL (optional for compatible providers)
S3_ENDPOINT=
# Whether to force path style
S3_FORCE_PATH_STYLE=false
# Whether to disable SSL
S3_DISABLE_SSL=false
# S3 storage path prefix
S3_PATH=

# Qiniu Storage Configuration
# Qiniu access key
QINIU_ACCESS_KEY=
# Qiniu secret key
QINIU_SECRET_KEY=
# Qiniu bucket name
QINIU_BUCKET_NAME=
# Qiniu domain
QINIU_DOMAIN=
# Qiniu zone
QINIU_ZONE=
# Whether to use HTTPS
QINIU_USE_HTTPS=true
# Qiniu storage path prefix
QINIU_PATH=

# Vector Storage Configuration
# Vector storage type
VECTOR_STORE=weaviate
# Weaviate endpoint
WEAVIATE_ENDPOINT=http://localhost:18080
# Weaviate API key
WEAVIATE_API_KEY=
# Whether to enable gRPC
WEAVIATE_GRPC_ENABLED=false
# Keyword data source type
KEYWORD_DATA_SOURCE_TYPE=database
# Indexing batch size for batch embedding and vector writes
# Note that when setting this parameter, you must check the maximum batch size supported by the embedding interface. For example, the maximum batch size for QWEN text-embedding-v4 is 10.
INDEXING_BATCH_SIZE=4
# Maximum segmentation tokens for indexing
INDEXING_MAX_SEGMENTATION_TOKENS_LENGTH=4000
# Maximum indexing workers
INDEXING_MAX_WORKERS=4
# Maximum indexing timeout in minutes (default: 60, minimum: 5)
INDEXING_TIMEOUT_MINUTES=60
# Neo4j Configuration
# Neo4j Bolt URI
NEO4J_URI=bolt://localhost:7687
# Neo4j username
NEO4J_USERNAME=neo4j
# Neo4j password
NEO4J_PASSWORD=
# Neo4j database name
NEO4J_DATABASE=neo4j

## Upload Configuration
# File upload size limit (MB)
UPLOAD_FILE_SIZE_LIMIT=15
# Batch upload file count limit
UPLOAD_FILE_BATCH_LIMIT=5
# Batch upload limit
BATCH_UPLOAD_LIMIT=10
# Image upload size limit (MB)
UPLOAD_IMAGE_FILE_SIZE_LIMIT=10
# Video upload size limit (MB)
UPLOAD_VIDEO_FILE_SIZE_LIMIT=100
# Audio upload size limit (MB)
UPLOAD_AUDIO_FILE_SIZE_LIMIT=50
# Workflow file upload limit
WORKFLOW_FILE_UPLOAD_LIMIT=10
# Enterprise storage quota (GB)
ENTERPRISE_STORAGE_QUOTA_GB=20

## Email Configuration
# Email service type (resend/smtp)
EMAIL_MAIL_TYPE=resend
# Default sender
EMAIL_MAIL_DEFAULT_SEND_FROM=noreply@example.com
# Resend API key. Required in CLOUD mode or when Resend-backed email features are enabled.
EMAIL_RESEND_API_KEY=
# Resend API URL
EMAIL_RESEND_API_URL=https://api.resend.com
# SMTP server
EMAIL_SMTP_SERVER=smtp.gmail.com
# SMTP port
EMAIL_PORT=587
# SMTP username
EMAIL_SMTP_USERNAME=
# SMTP password
EMAIL_SMTP_PASSWORD=
# Whether to use TLS
EMAIL_SMTP_USE_TLS=false
# Whether to use opportunistic TLS
EMAIL_SMTP_OPPORTUNISTIC_TLS=false
# Email template logo
EMAIL_MAIL_TEMPLATE_LOGO_URL=
# Email brand name
EMAIL_MAIL_TEMPLATE_BRAND_NAME=ZGI
# Console web URL
EMAIL_CONSOLE_WEB_URL=http://localhost:3000

## Message Queue Configuration
# Task queue reuses the main Redis host, port, and password above.
# Task queue Redis database
TASK_QUEUE_REDIS_DB=1
# Task queue concurrency
TASK_QUEUE_CONCURRENCY=4
# Task retention time
TASK_QUEUE_RETENTION=24h
# Task queue environment prefix
TASK_QUEUE_ENV_PREFIX=LOCAL
# Whether to enable automation due-task dispatch registration.
# Set to false in local development when sharing database/Redis with test environments,
# so the local instance does not scan and claim scheduled automation tasks.
AUTOMATION_DISPATCH_ENABLED=true

## Other Service Configuration
# Plugin Configuration
# Whether to enable plugin runner integration
PLUGIN_RUNNER_ENABLED=false
# Plugin runner service URL
PLUGIN_RUNNER_URL=http://localhost:2665
# Plugin runner API key
PLUGIN_RUNNER_API_KEY=
# Plugin runner timeout (seconds)
PLUGIN_RUNNER_TIMEOUT=30

# Marketplace Configuration
# Marketplace API URL
MARKETPLACE_API_URL=
# Marketplace base URL
MARKETPLACE_BASE_URL=
# Marketplace source identifier
MARKETPLACE_SOURCE=

# ETL Configuration
# ETL type (zgi/Unstructured/LandingAI/Reducto/Mixed/Hyperparse)
ETL_TYPE=zgi
# Unstructured API URL
UNSTRUCTURED_API_URL=
# Unstructured API key
UNSTRUCTURED_API_KEY=
# LandingAI API key
LANDINGAI_API_KEY=
# REDUCTO API KEY
REDUCTO_API_KEY=
# Hyperparse native PDF extractor switch (for Mixed mode routing and explicit Hyperparse mode)
ETL_HYPERPARSE_ENABLED=true
# Hyperparse SDK backend: local|mineru|reducto.
# VLM parsing uses the system default vision model, not .env model keys.
ETL_HYPERPARSE_BACKEND=mineru
# Optional local OCR overrides. Defaults are auto-detected.
# CONTENT_PARSE_OCR_LANG=chi_sim+eng
# CONTENT_PARSE_OCR_TIMEOUT_SECONDS=20
# CONTENT_PARSE_LOCAL_OCR_MAX_PAGES=8
# Code Execution Configuration
# Code execution service endpoint
CODE_EXECUTION_ENDPOINT=http://localhost:2660
# Code execution API key
CODE_EXECUTION_API_KEY=
# Maximum number
CODE_MAX_NUMBER=9223372036854775807
# Minimum number
CODE_MIN_NUMBER=-9223372036854775808
# Maximum string length
CODE_MAX_STRING_LENGTH=80000

# Console Configuration
# Console API URL
CONSOLE_API_URL=http://127.0.0.1:2679
# Console gRPC address
CONSOLE_API_GRPC_ADDR=
# Internal console API key
CONSOLE_INTERNAL_API_KEY=
# Enable strict validation for official model sync snapshots.
# Default disabled: accept upstream snapshots as-is without empty/shrink rejection.
OFFICIAL_MODEL_SYNC_STRICT_MODE=false
# LLM provider credential encryption key. Leave empty to use the development default.
LLM_ENCRYPTION_KEY=
# Optional system-level policy prompt injected before generated LLM requests.
# Keep disabled for open-source defaults. Use either TEXT or FILE when enabled; TEXT wins.
LLM_POLICY_PROMPT_ENABLED=false
LLM_POLICY_PROMPT_FILE=
LLM_POLICY_PROMPT_TEXT=
# ModelMeta API URL. Used to sync official provider and model metadata.
# ZGI appends /v1 internally, so do not include /v1 here.
MODELMETA_API_URL=https://api.modelmeta.dev

# Workflow Configuration
# Maximum workflow execution time in seconds
WORKFLOW_EXECUTION_TIMEOUT=3600
# Maximum LLM node execution time in seconds
WORKFLOW_LLM_TIMEOUT=1200
# Heartbeat interval in seconds to keep connection alive
WORKFLOW_HEARTBEAT_INTERVAL=5
# Timeout for cleanup operations in seconds
WORKFLOW_CLEANUP_TIMEOUT=30

# Workflow File Extraction Configuration
# Whether to enable workflow file extraction
WORKFLOW_FILE_EXTRACTION_ENABLED=true
# Maximum content size (bytes)
WORKFLOW_FILE_EXTRACTION_MAX_CONTENT_SIZE=1048576
# Extraction timeout (seconds)
WORKFLOW_FILE_EXTRACTION_TIMEOUT=10
# Whether to enable caching
WORKFLOW_FILE_EXTRACTION_CACHE_ENABLED=true
# Extraction strategy for workflow file extraction
WORKFLOW_FILE_EXTRACTION_STRATEGY=
# Whether to run contentparse shadow output during dataset indexing
# Optional shadow pass for comparing content parse artifacts during dataset indexing.
# CONTENT_PARSE_SHADOW_DATASET_INDEXING_ENABLED=false

# Answer Node Streaming Configuration
# Answer node output chunk size
ANSWER_NODE_STREAMING_CHUNK_SIZE=20

# Optional Notification SMS Configuration
# Enables the workflow notification-sms node and automation SMS notification channel.
# Leave disabled or unset if this deployment does not use notification SMS.
# NOTIFICATION_SMS_ENABLED=false
# NOTIFICATION_SMS_PROVIDERS=chuanglan
# NOTIFICATION_SMS_DEFAULT_PROVIDER=chuanglan
# Optional default template key. If omitted, the first configured template is used.
# NOTIFICATION_SMS_TEMPLATE=pending_action_notification
# Required when notification SMS is enabled. The frontend can choose one of these template keys.
# Provider credentials use the provider-level env vars below; provider template IDs and param mappings live here.
# Params without required default to required. required:false means the field may be omitted and is not sent to the provider when empty.
# NOTIFICATION_SMS_TEMPLATES_JSON=[{"key":"pending_action_notification","name":"Pending action notification","preview_template":"Hello {{notification_title}}, link code {{link_code}}, remark {{remark}}.","params":[{"key":"notification_title","label":"Notification title","required":true,"max_length":64},{"key":"link_code","label":"Link code","required":true,"pattern":"^[A-Za-z0-9]+$"},{"key":"remark","label":"Remark","required":false}],"chuanglan":{"template_id":"","template_text":"Hello {s}, link code {s}, remark {s}","param_order":["notification_title","link_code","remark"]},"aliyun":{"template_code":"","param_map":{"notification_title":"name","link_code":"code","remark":"remark"}}}]

# Chuanglan notification SMS provider
# NOTIFICATION_SMS_CHUANGLAN_ACCOUNT=
# NOTIFICATION_SMS_CHUANGLAN_PASSWORD=
# NOTIFICATION_SMS_CHUANGLAN_API_URL=https://smssh.253.com/msg/sms/v2/tpl/send
# NOTIFICATION_SMS_CHUANGLAN_SIGNATURE=
# NOTIFICATION_SMS_CHUANGLAN_EXTEND=
# NOTIFICATION_SMS_CHUANGLAN_REPORT=false

# Aliyun notification SMS provider
# NOTIFICATION_SMS_ALIYUN_ACCESS_KEY_ID=
# NOTIFICATION_SMS_ALIYUN_ACCESS_KEY_SECRET=
# NOTIFICATION_SMS_ALIYUN_SIGN_NAME=
# NOTIFICATION_SMS_ALIYUN_API_URL=

# SQL Base Configuration
# SQL Base type (external/internal)
SQL_BASE_TYPE=internal

# SQL Base External Configuration
SQL_BASE_EXTERNAL_URL=
# SQL Base external API key
SQL_BASE_EXTERNAL_API_KEY=

# SQL Base Internal Configuration
# SQL Base internal mode reuses DB_HOST, DB_PORT, DB_USERNAME, and DB_PASSWORD above.
SQL_BASE_INTERNAL_DB=zgi_sql_base

# Stored API key encryption key outside the LLM module. Required outside local/dev; must be 32 bytes.
API_KEY_ENCRYPTION_KEY=
# LLM credential secret key (must be 32 bytes when set; falls back to API_KEY_ENCRYPTION_KEY if empty)
LLM_CREDENTIAL_SECRET_KEY=
## Observability Configuration
# OpenTelemetry tracing. Configure an OTLP endpoint or Langfuse direct export before enabling.
# Leave OTEL_EXPORTER_OTLP_ENDPOINT empty when using direct Langfuse export below.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=zgi-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# 1.0 records all sampled traces. Lower this, for example 0.1, for high-traffic deployments.
OTEL_TRACES_SAMPLE_RATE=1.0
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_TRACES_HEADERS=
# Performance span switches. All are ignored when OTEL_ENABLED=false.
OTEL_INSTRUMENT_HTTP_CLIENT=true
OTEL_INSTRUMENT_WORKFLOW=true
OTEL_INSTRUMENT_DB=false
OTEL_INSTRUMENT_REDIS=false
OTEL_INSTRUMENT_GRPC=false
# Langfuse semantic attributes for LLM spans. Ignored when OTEL_ENABLED=false.
OTEL_LLM_LANGFUSE_ATTRIBUTES=true
# none: no prompt/output, summary: counts only, full: serialized prompt/output.
OTEL_LLM_CAPTURE_CONTENT=summary
# Max characters for serialized LLM input/output attributes. 0 disables truncation.
OTEL_LLM_CAPTURE_MAX_CHARS=65536
# Local host ports used by the Docker Compose observability profile.
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
# Collector config mounted by the Docker Compose observability profile.
# Use docker/otel-collector.debug.yaml to print traces in Collector logs.
# Use docker/otel-collector.external-jaeger.yaml to export to an external Jaeger.
# Use docker/otel-collector.external-langfuse.yaml to export to one external Langfuse backend.
# Use docker/otel-collector.external-jaeger-langfuse.yaml to export to external Jaeger and one Langfuse backend.
OTEL_COLLECTOR_CONFIG=./docker/otel-collector.debug.yaml
# External observability platform endpoints consumed by the Collector.
# For docker/observability/jaeger recipes, use host.docker.internal:14317.
JAEGER_OTLP_ENDPOINT=<jaeger-host>:4317
# Direct Langfuse export. Becomes active when OTEL_ENABLED=true and keys are configured
# without a custom OTLP endpoint. Set LANGFUSE_ENABLED=true to force direct export.
# LANGFUSE_BASE_URL is used to derive https://<host>/api/public/otel.
# Set LANGFUSE_ENABLED=false to explicitly ignore configured Langfuse keys.
# LANGFUSE_AUTH_STRING alone is for Collector mode and does not redirect API traces.
LANGFUSE_ENABLED=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Optional override for Cloud regions or self-hosted deployments, for example:
# https://jp.cloud.langfuse.com/api/public/otel
# https://<langfuse-domain>/api/public/otel
LANGFUSE_OTEL_ENDPOINT=
# Optional manual base64 of "<public_key>:<secret_key>". Usually not needed when keys above are set.
LANGFUSE_AUTH_STRING=

## Misc Configuration
# Whether knowledge retrieval rate limiting is enabled
KNOWLEDGE_RATE_LIMIT_ENABLED=false
# Knowledge retrieval rate limit window in milliseconds
KNOWLEDGE_RATE_LIMIT_WINDOW_MS=
# Knowledge retrieval rate limit max requests
KNOWLEDGE_RATE_LIMIT_MAX=
# Whether sync commands run without database writes
DRY_RUN=false

# MinerU access mode. sidecar uses a local/custom /file_parse service; official uses MinerU Precision Extract API.
# MINERU_MODE=sidecar
# Official MinerU Precision Extract API settings. Used only when MINERU_MODE=official.
# MINERU_OFFICIAL_BASE_URL=https://mineru.net
# MINERU_OFFICIAL_TOKEN=
# MINERU_OFFICIAL_MODEL_VERSION=vlm
# MINERU_OFFICIAL_POLL_INTERVAL_SECONDS=3
# MINERU_OFFICIAL_TIMEOUT_SECONDS=800
# Custom MinerU sidecar endpoint. Empty means the SDK default http://127.0.0.1:18091.
# MINERU_API_URL=
# Optional Bearer token for a custom MinerU sidecar.
# MINERU_API_TOKEN=
# MINERU_TIMEOUT_SECONDS=800
