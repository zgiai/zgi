## Usage Instructions
# 1. Copy this file to `.env.docker` when you start the API with Docker Compose
# 2. The values below are for container-to-container access inside the Docker Compose network
# 3. Service hosts use Docker Compose service names such as `postgres` and `redis`
# 4. Optional services such as `weaviate`, `sandbox`, and `runner` are enabled by default through Docker Compose profiles
# 5. Adjust the values only when you rename services or connect to external infrastructure

## Basic Configuration
# Application name
APP_NAME=ZGI-GinKit

# Server Configuration
# Server running mode inside Docker
SERVER_MODE=release
# Environment marker for local Docker Compose. Set ENV=production only after
# replacing all placeholder secrets with generated production values.
ENV=local
# Server listening port inside container
SERVER_PORT=2670
# Read timeout (seconds)
SERVER_READ_TIMEOUT=3600
# Write timeout (seconds)
SERVER_WRITE_TIMEOUT=3600
# Secret key for JWT signing and file signatures. Generate a unique value before production use.
SECRET_KEY=replace-with-strong-random-secret
# File access URL exposed by the API container
FILES_URL=http://localhost:2679
# Default sender address
EMAIL_MAIL_DEFAULT_SEND_FROM=noreply@example.com
# Resend API key. Required in CLOUD mode or when Resend-backed email features are enabled.
EMAIL_RESEND_API_KEY=

## Log Configuration
# Log level (debug/info/warn/error). Container defaults should stay quiet unless explicitly overridden.
LOG_LEVEL=info
# Log file path inside the container. Mount this directory to persist logs.
LOG_FILENAME=/app/logs/app.log
# Maximum size of a single log file (MB)
LOG_MAX_SIZE=100
# Log file retention days
LOG_MAX_AGE=15
# Maximum number of old log files to retain
LOG_MAX_BACKUPS=7
# Whether to compress old log files
LOG_COMPRESS=true

## Database Configuration
# Database driver
DB_DRIVER=postgres
# Database host (Docker Compose service name)
DB_HOST=postgres
# Database port inside Docker network
DB_PORT=5432
# Database username
DB_USERNAME=postgres
# Database password
DB_PASSWORD=
# Database name
DB_NAME=zgi
# SSL mode
DB_SSLMODE=disable

## Redis Configuration
# Redis host (Docker Compose service name)
REDIS_HOST=redis
# Redis port inside Docker network
REDIS_PORT=6379
# Redis password
REDIS_PASSWORD=

## Task Queue Configuration
# Task queue reuses the main Redis host, port, and password above.
# Task queue Redis database
TASK_QUEUE_REDIS_DB=1
# Task retention time
TASK_QUEUE_RETENTION=24h

## Storage Configuration
# Storage type
STORAGE_TYPE=opendal
# OpenDAL/local base path inside container
OPENDAL_BASE_PATH=/app/storage/opendal

## Vector and Graph Configuration
# Vector storage type. The default Docker stack starts Weaviate so knowledge base features work immediately.
# Use `./dev/start-docker --core` to run without Weaviate.
VECTOR_STORE=weaviate
# Weaviate endpoint (Docker Compose service name).
WEAVIATE_ENDPOINT=http://weaviate:8080
# Whether to enable gRPC
WEAVIATE_GRPC_ENABLED=false
# Keyword data source type
KEYWORD_DATA_SOURCE_TYPE=database

## SQL Base Configuration
# SQL Base type
SQL_BASE_TYPE=internal
# SQL Base internal mode reuses DB_HOST, DB_PORT, DB_USERNAME, and DB_PASSWORD above.
# SQL Base internal database
SQL_BASE_INTERNAL_DB=zgi_sql_base

## Code Execution Configuration
# Remote code execution endpoint on the shared Docker network.
CODE_EXECUTION_ENDPOINT=http://zgi-sandbox:2660
# Sandbox API key
CODE_EXECUTION_API_KEY=
# Sandbox adapter connect timeout in seconds
CODE_EXECUTION_CONNECT_TIMEOUT_SECONDS=5
# Sandbox creation request timeout in seconds
CODE_EXECUTION_CREATE_TIMEOUT_SECONDS=10
# Skill archive upload timeout in seconds
CODE_EXECUTION_UPLOAD_TIMEOUT_SECONDS=30
# Extra HTTP time beyond the skill command timeout in seconds
CODE_EXECUTION_COMMAND_TIMEOUT_PADDING_SECONDS=15
# Artifact list and download timeout in seconds
CODE_EXECUTION_ARTIFACT_TIMEOUT_SECONDS=10
# Sandbox cleanup timeout in seconds
CODE_EXECUTION_CLEANUP_TIMEOUT_SECONDS=5
# Legacy workflow /v1/sandbox/run network access. Keep false for preview sandbox.
CODE_EXECUTION_ENABLE_NETWORK=false

## Plugin Runner Configuration
# Whether to enable plugin runner integration inside Docker Compose.
PLUGIN_RUNNER_ENABLED=true
# Plugin runner service URL on the shared Docker network
PLUGIN_RUNNER_URL=http://runner:2665
# Plugin runner API key; keep this aligned with runner/.env
PLUGIN_RUNNER_API_KEY=
# Plugin runner timeout in seconds
PLUGIN_RUNNER_TIMEOUT=30

## Upload Configuration
# Batch upload limit
BATCH_UPLOAD_LIMIT=10

## Email Configuration
# SMTP server
EMAIL_SMTP_SERVER=smtp.gmail.com
# SMTP port
EMAIL_PORT=587
# SMTP username
EMAIL_SMTP_USERNAME=
# SMTP password
EMAIL_SMTP_PASSWORD=
# Whether to use TLS
EMAIL_SMTP_USE_TLS=false
# Whether to use opportunistic TLS
EMAIL_SMTP_OPPORTUNISTIC_TLS=false

## ModelMeta Configuration
# ModelMeta-compatible API URL for curated model metadata sync.
# Set to https://models.zgi.ai to sync from the official ZGI Models service.
MODELMETA_API_URL=https://models.zgi.ai

## Error Reporting
# Sentry DSN for error reporting (optional)
# For TEST-A, use the converted SDK DSN:
# https://<public-key>@sentry.example.com/<project-id>
SENTRY_DSN=
# Sentry environment label for grouping events. Defaults to ENV when empty.
# For TEST-A deployment, set SENTRY_ENVIRONMENT=TEST-A.
SENTRY_ENVIRONMENT=

## Workflow Configuration
# Maximum workflow execution time in seconds
WORKFLOW_EXECUTION_TIMEOUT=3600
# Maximum LLM node execution time in seconds
WORKFLOW_LLM_TIMEOUT=1200
# Heartbeat interval in seconds to keep connection alive
WORKFLOW_HEARTBEAT_INTERVAL=5
# Timeout for cleanup operations in seconds
WORKFLOW_CLEANUP_TIMEOUT=30
# Workflow image input URL mode for LLM/vision calls.
# Keep zgi_proxy unless the storage object is publicly readable and models can GET it directly.
WORKFLOW_IMAGE_INPUT_URL_MODE=zgi_proxy
# Optional public storage/CDN base URL. Not an upload URL and not a ZGI API URL.
# Leave empty to infer aliyun-oss/qiniu public URLs from storage config.
# Docker default STORAGE_TYPE=opendal cannot be inferred; public_storage_url mode requires this value.
# Example final URL: https://cdn.example.com/{objectKey}
WORKFLOW_IMAGE_INPUT_PUBLIC_BASE_URL=
# Whether to run contentparse shadow output during dataset indexing
CONTENT_PARSE_SHADOW_DATASET_INDEXING_ENABLED=false

## Answer Node Streaming Configuration
# Answer node output chunk size
ANSWER_NODE_STREAMING_CHUNK_SIZE=20

## Startup Configuration
# Whether to wait for database to be ready before startup
WAIT_FOR_DB=true
# Whether to run migrations automatically on startup
MIGRATION_ENABLED=true
# Whether to run seed data automatically after migrations
SEED_ENABLED=true

# Stored API key encryption key. `dev/bootstrap` fills local env files
# automatically. For production, replace it with a unique 32-byte secret.
API_KEY_ENCRYPTION_KEY=
LLM_ENCRYPTION_KEY=
# Validate literal outbound LLM URLs and IP hosts before requests.
LLM_GUARD_OUTBOUND_URL=true
# Validate DNS-resolved outbound LLM addresses. Keep disabled by default for fake-ip DNS.
LLM_GUARD_OUTBOUND_DNS=false
# LLM credential secret key. Optional when API_KEY_ENCRYPTION_KEY is set; must be 32 bytes when set.
LLM_CREDENTIAL_SECRET_KEY=

## Observability Configuration
# Disabled by default. Enable only when the observability profile or an external Collector is running.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=zgi-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# 1.0 records all sampled traces. Lower this, for example 0.1, for high-traffic deployments.
OTEL_TRACES_SAMPLE_RATE=1.0
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_TRACES_HEADERS=
# Performance span switches. All are ignored when OTEL_ENABLED=false.
OTEL_INSTRUMENT_HTTP_CLIENT=true
OTEL_INSTRUMENT_WORKFLOW=true
OTEL_INSTRUMENT_DB=false
OTEL_INSTRUMENT_REDIS=false
OTEL_INSTRUMENT_GRPC=false
# Langfuse semantic attributes for LLM spans. Ignored when OTEL_ENABLED=false.
OTEL_LLM_LANGFUSE_ATTRIBUTES=true
# none: no prompt/output, summary: counts only, full: serialized prompt/output.
OTEL_LLM_CAPTURE_CONTENT=summary
# Max characters for serialized LLM input/output attributes. 0 disables truncation.
OTEL_LLM_CAPTURE_MAX_CHARS=65536
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
# Collector config mounted by the Docker Compose observability profile.
# Use docker/otel-collector.debug.yaml to print traces in Collector logs.
# Use docker/otel-collector.external-jaeger.yaml to export to an external Jaeger.
# Use docker/otel-collector.external-langfuse.yaml to export to one external Langfuse backend.
# Use docker/otel-collector.external-jaeger-langfuse.yaml to export to external Jaeger and one Langfuse backend.
OTEL_COLLECTOR_CONFIG=./docker/otel-collector.debug.yaml
# External observability platform endpoints consumed by the Collector.
# For docker/observability/jaeger recipes, use host.docker.internal:14317.
JAEGER_OTLP_ENDPOINT=<jaeger-host>:4317
# Direct Langfuse export. Docker defaults to the local Collector endpoint, so set
# LANGFUSE_ENABLED=true when the API should bypass the Collector and export directly.
# LANGFUSE_BASE_URL is used to derive https://<host>/api/public/otel.
# Set LANGFUSE_ENABLED=false to explicitly ignore configured Langfuse keys.
# LANGFUSE_AUTH_STRING alone is for Collector mode and does not redirect API traces.
LANGFUSE_ENABLED=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Optional override for Cloud regions or self-hosted deployments, for example:
# https://jp.cloud.langfuse.com/api/public/otel
# https://<langfuse-domain>/api/public/otel
LANGFUSE_OTEL_ENDPOINT=
# Optional manual base64 of "<public_key>:<secret_key>". Usually not needed when keys above are set.
LANGFUSE_AUTH_STRING=

# ============================================================================
# Hyperparse / MinerU Configuration
# ============================================================================
# ETL type: zgi|Unstructured|LandingAI|Reducto|Mixed|Hyperparse.
ETL_TYPE=zgi
# Third-party ETL provider settings.
UNSTRUCTURED_API_URL=
UNSTRUCTURED_API_KEY=
LANDINGAI_API_KEY=
REDUCTO_API_KEY=

# Hyperparse native extractor switch and mode.
ETL_HYPERPARSE_ENABLED=true
# Hyperparse SDK backend: local|mineru|reducto.
# VLM parsing uses the system default vision model, not .env model keys.
ETL_HYPERPARSE_BACKEND=mineru

# Optional local OCR overrides. Defaults are auto-detected.
# CONTENT_PARSE_OCR_LANG=chi_sim+eng
# CONTENT_PARSE_OCR_TIMEOUT_SECONDS=20
# CONTENT_PARSE_LOCAL_OCR_MAX_PAGES=8

# MinerU access mode: sidecar uses a local/custom /file_parse service; official uses MinerU Precision Extract API.
# MINERU_MODE=sidecar

# Custom sidecar endpoint. Empty means the SDK default http://127.0.0.1:18091.
# MINERU_API_URL=https://mineru.example.com
# MINERU_API_TOKEN=
# MINERU_TIMEOUT_SECONDS=800

# Official MinerU Precision Extract API settings. Used only when MINERU_MODE=official.
# MINERU_OFFICIAL_BASE_URL=https://mineru.net
# MINERU_OFFICIAL_TOKEN=
# MINERU_OFFICIAL_MODEL_VERSION=vlm
# MINERU_OFFICIAL_POLL_INTERVAL_SECONDS=3
# MINERU_OFFICIAL_TIMEOUT_SECONDS=800
