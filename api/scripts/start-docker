#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

usage() {
  cat <<'EOF'
Usage: ./scripts/start-docker [--china]

Options:
  --china   Use recommended China mainland mirrors for the Docker build.
EOF
}

copy_env_if_missing() {
  if [ -f "$ROOT/.env.docker" ]; then
    echo "[api/start-docker] keep existing .env.docker"
    return 0
  fi

  if [ ! -f "$ROOT/.env.docker.example" ]; then
    echo "[api/start-docker] missing template: $ROOT/.env.docker.example" >&2
    exit 1
  fi

  cp "$ROOT/.env.docker.example" "$ROOT/.env.docker"
  echo "[api/start-docker] created .env.docker from .env.docker.example"
}

configure_china_build_env() {
  export BUILD_REGION=cn
  export GOPROXY="${GOPROXY:-https://goproxy.cn,direct}"
  export APK_MIRROR="${APK_MIRROR:-mirrors.aliyun.com}"
  echo "[api/start-docker] build region: china"
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --china)
      configure_china_build_env
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "[api/start-docker] unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

copy_env_if_missing

cd "$ROOT"
docker compose up -d --build
