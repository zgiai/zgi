# EditorConfig is awesome: https://EditorConfig.org

# Top-level configuration file
root = true

# Common rules for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Go file rules
[*.go]
indent_style = tab
indent_size = 4

# YAML file rules
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown file rules
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# SQL file rules
[*.sql]
indent_style = space
indent_size = 4

# Configuration file rules
[*.{json,toml}]
indent_style = space
indent_size = 2
